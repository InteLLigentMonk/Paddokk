# API Configuration
VITE_API_URL=http://localhost:5037

# Better Auth Configuration
# Better Auth Secret (REQUIRED)
# Generate with: openssl rand -base64 32
# Minimum 32 characters, use different values for dev/staging/prod
# For production: Store in AWS Secrets Manager / Azure Key Vault
BETTER_AUTH_SECRET=

# Better Auth URL (REQUIRED)
# Development: http://localhost:3000
# Production: https://your-domain.com
# Note: VITE_ prefix required for client-side access
VITE_BETTER_AUTH_URL=http://localhost:3000

# Database Connection String (REQUIRED)
# Format: postgresql://user:password@host:port/database
BETTER_AUTH_DB_CONNECTION_STRING=

# JWT Private Key (REQUIRED for asymmetric signing)
# Generate with: openssl genrsa -out private.pem 2048
# For production: Store in AWS Secrets Manager / Azure Key Vault
# Load from file: $(cat private.pem)
JWT_PRIVATE_KEY=

# Email Configuration
# RESEND_API_KEY: Sending-only API key from resend.com, scoped to mail.paddokk.com
# Without this key, emails are logged to console (dev fallback).
RESEND_API_KEY=
# Sender address shown in mail clients. Must use a Resend-verified domain.
EMAIL_FROM_ADDRESS=Paddokk <noreply@mail.paddokk.com>

# Social OAuth (OPTIONAL)
# Server-only (no VITE_ prefix) so secrets never reach the client bundle.
# A provider's login button is automatically disabled until BOTH its id and
# secret are set, so it's safe to leave these blank in environments where the
# OAuth app hasn't been provisioned yet.
# Local dev: set here in .env.local. Production: resolve via Key Vault / env.
#
# Register this authorized redirect URI in each provider's console
# (origin = VITE_BETTER_AUTH_URL):
#   Google:   <origin>/api/auth/callback/google
#   Facebook: <origin>/api/auth/callback/facebook
#
# Google OAuth client (Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Facebook OAuth app (Meta Developer Console)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
