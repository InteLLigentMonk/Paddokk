{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit -m *)",
      "Bash(git push:*)",
      "Bash(ls *)",
      "Bash(echo:*)",
      "Bash(cat *)",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(netstat:*)",
      "Bash(findstr:*)",
      "Bash(taskkill:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_github_github__*",
      "Bash(curl:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Look at this Bash command: $ARGUMENTS\n\nIf the command contains 'git commit', output exactly this message:\n💡 Consider running /update-docs to sync documentation with your changes (or skip if already up-to-date).\n\nIf the command does NOT contain 'git commit', output: SKIP\n\nBe very brief.",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs npx prettier --write 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
